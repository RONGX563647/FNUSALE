# 校园二手交易平台 - Git 忽略配置

# ==================== 环境配置 ====================
# 敏感信息 - 禁止提交
.env
*.env.local

# ==================== 编译输出 ====================
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# Gradle
.gradle/
build/
!gradle-wrapper.jar

