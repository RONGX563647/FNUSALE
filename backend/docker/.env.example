# 校园二手交易平台 - 环境变量配置模板
# 复制此文件为 .env 并修改相应的值

# ==================== MySQL 配置 ====================
MYSQL_PORT=3307
MYSQL_DATABASE=fnusale
MYSQL_USER=fnusale
MYSQL_PASSWORD=fnusale123456
MYSQL_ROOT_PASSWORD=root123456

# ==================== Redis 配置 ====================
REDIS_PORT=6379
REDIS_PASSWORD=redis123456

# ==================== Elasticsearch 配置 ====================
ES_PORT=9200

# ==================== MinIO 配置 ====================
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USER=admin
MINIO_PASSWORD=minio123456

# ==================== Nacos 配置 ====================
NACOS_PORT=8848
NACOS_AUTH_TOKEN=SecretKey012345678901234567890123456789012345678901234567890123456789

# ==================== Sentinel 配置 ====================
SENTINEL_PORT=8858
SENTINEL_USER=sentinel
SENTINEL_PASSWORD=sentinel123456

# ==================== RabbitMQ 配置 ====================
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=rabbitmq123456

# ==================== Prometheus 配置 ====================
PROMETHEUS_PORT=9090

# ==================== Grafana 配置 ====================
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=grafana123456